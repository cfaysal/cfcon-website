---
interface Props {
  title: string;
  src: string;
  alt: string;
}

const { title, src, alt } = Astro.props;
---

<div>
  <h3 class="text-sm font-medium text-text-light mb-2">{title}</h3>
  <div class="glass-card rounded-2xl overflow-hidden p-1">
    <img src={src} alt={alt} class="rounded-xl w-full lightbox-trigger" loading="lazy" />
  </div>
</div>
