---
interface Step {
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
const colClass = `grid grid-cols-1 md:grid-cols-${steps.length} gap-4`;
---

<div class:list={[colClass, 'stagger-children']}>
  {steps.map((step, i) => (
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-primary mb-2">{i + 1}</div>
      <h3 class="font-semibold mb-1">{step.title}</h3>
      <p class="text-text-light text-sm">{step.description}</p>
    </div>
  ))}
</div>
