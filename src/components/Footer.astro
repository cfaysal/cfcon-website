---
const year = new Date().getFullYear();
---

<footer class="bg-surface-dark border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 stagger-children">
      <!-- Company -->
      <div>
        <h3 class="font-bold text-lg mb-4 text-text">CFCON</h3>
        <p class="text-text-light text-sm leading-relaxed">
          Atlassian Consulting & Marketplace Apps. We help teams optimize their workflows and get the most out of the Atlassian ecosystem.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-bold text-lg mb-4 text-text">Links</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/apps" class="text-text-light hover:text-primary transition-colors">Apps</a></li>
          <li><a href="/insights" class="text-text-light hover:text-primary transition-colors">Insights</a></li>
          <li><a href="/about" class="text-text-light hover:text-primary transition-colors">About</a></li>
          <li><a href="/contact" class="text-text-light hover:text-primary transition-colors">Contact</a></li>
          <li><a href="https://marketplace.atlassian.com/vendors/69072148" target="_blank" rel="noopener" class="text-text-light hover:text-primary transition-colors">Atlassian Marketplace</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-bold text-lg mb-4 text-text">Legal</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/privacy" class="text-text-light hover:text-primary transition-colors">Privacy Policy</a></li>
          <li><a href="/eula" class="text-text-light hover:text-primary transition-colors">EULA</a></li>
          <li><a href="/imprint" class="text-text-light hover:text-primary transition-colors">Imprint</a></li>
        </ul>
        <div class="mt-6 flex items-center gap-4">
          <a href="mailto:support@cfcon.org" class="text-text-light hover:text-primary transition-colors text-sm">support@cfcon.org</a>
          <a href="https://www.linkedin.com/in/cfaysal/" target="_blank" rel="noopener" class="text-text-light hover:text-primary transition-colors" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="section-divider mt-12 mb-8"></div>
    <div class="text-center text-sm text-text-light">
      &copy; {year} CFCON. All rights reserved.
    </div>
  </div>
</footer>
