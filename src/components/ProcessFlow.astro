---
const steps = [
  {
    number: '01',
    title: 'Experience',
    description: 'Over a decade of hands-on Atlassian consulting & admin work',
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    number: '02',
    title: 'Concept',
    description: 'Market research, architecture, UX design & strategic planning',
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    number: '03',
    title: 'Development',
    description: 'Clean code on Atlassian Forge — no external servers',
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    number: '04',
    title: 'Testing',
    description: 'Real-world testing, performance tuning & hardening',
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19 14.5M14.25 3.104c.251.023.501.05.75.082M19 14.5l-2.47 7.94A2.25 2.25 0 0 1 14.38 24H9.62a2.25 2.25 0 0 1-2.15-1.56L5 14.5m14 0H5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    number: '05',
    title: 'Shipping',
    description: 'Published on the Atlassian Marketplace — ready for you',
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];
---

<div class="process-flow fade-in">
  <!-- Connecting line (desktop) -->
  <div class="process-line" aria-hidden="true">
    <div class="process-line-fill"></div>
  </div>

  <div class="process-steps stagger-children">
    {steps.map((step, i) => (
      <div class="process-step" data-step={i}>
        <div class="process-icon-wrap">
          <div class="process-pulse" />
          <div class="process-icon" set:html={step.icon} />
        </div>
        <div class="process-number">{step.number}</div>
        <h3 class="process-title">{step.title}</h3>
        <p class="process-desc">{step.description}</p>
      </div>
    ))}
  </div>
</div>

<style>
  .process-flow {
    position: relative;
    padding: 2rem 0;
  }

  /* ── Connecting line ── */
  .process-line {
    display: none;
  }
  @media (min-width: 768px) {
    .process-line {
      display: block;
      position: absolute;
      top: 74px;
      left: 10%;
      right: 10%;
      height: 2px;
      background: rgba(61, 61, 61, 0.6);
      z-index: 0;
    }
    .process-line-fill {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, var(--color-primary), #00B8D9, #36B37E);
      transition: width 1.5s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 0 12px rgba(0, 184, 217, 0.4);
    }
    .process-flow.visible .process-line-fill {
      width: 100%;
    }
  }

  /* ── Steps grid ── */
  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .process-steps {
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
    }
  }

  /* ── Each step ── */
  .process-step {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Icon ── */
  .process-icon-wrap {
    position: relative;
    width: 64px;
    height: 64px;
    margin-bottom: 1rem;
  }
  .process-icon {
    width: 64px;
    height: 64px;
    background: rgba(42, 42, 42, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    position: relative;
    z-index: 1;
    transition: border-color 0.4s ease, box-shadow 0.4s ease, transform 0.4s ease;
  }
  .process-step[data-step="1"] .process-icon { color: #B44CC0; }
  .process-step[data-step="2"] .process-icon { color: #0065FF; }
  .process-step[data-step="3"] .process-icon { color: #00B8D9; }
  .process-step[data-step="4"] .process-icon { color: #36B37E; }
  .process-step:hover .process-icon {
    border-color: rgba(0, 184, 217, 0.4);
    box-shadow: 0 0 24px rgba(0, 184, 217, 0.15);
    transform: translateY(-3px);
  }

  /* Pulse ring behind icon */
  .process-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 20px;
    border: 1px solid rgba(212, 32, 39, 0.15);
    opacity: 0;
    z-index: 0;
  }
  .process-flow.visible .process-pulse {
    animation: pulse-ring 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  .process-step[data-step="0"] .process-pulse { animation-delay: 0s; }
  .process-step[data-step="1"] .process-pulse { animation-delay: 0.3s; }
  .process-step[data-step="2"] .process-pulse { animation-delay: 0.6s; }
  .process-step[data-step="3"] .process-pulse { animation-delay: 0.9s; }
  .process-step[data-step="4"] .process-pulse {
    animation-delay: 1.2s;
    border-color: rgba(54, 179, 126, 0.2);
  }

  @keyframes pulse-ring {
    0% { opacity: 0.6; transform: scale(1); }
    70% { opacity: 0; transform: scale(1.5); }
    100% { opacity: 0; transform: scale(1.5); }
  }

  /* ── Number ── */
  .process-number {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    margin-bottom: 0.35rem;
    opacity: 0.6;
  }
  .process-step[data-step="1"] .process-number { color: #B44CC0; }
  .process-step[data-step="2"] .process-number { color: #0065FF; }
  .process-step[data-step="3"] .process-number { color: #00B8D9; }
  .process-step[data-step="4"] .process-number { color: #36B37E; }

  /* ── Title ── */
  .process-title {
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.35rem;
    color: var(--color-text);
  }

  /* ── Description ── */
  .process-desc {
    font-size: 0.825rem;
    color: var(--color-text-light);
    line-height: 1.5;
    max-width: 180px;
  }

  /* ── Mobile: vertical line ── */
  @media (max-width: 767px) {
    .process-step {
      flex-direction: row;
      text-align: left;
      gap: 1.25rem;
    }
    .process-icon-wrap {
      flex-shrink: 0;
      margin-bottom: 0;
    }
    .process-desc {
      max-width: none;
    }
    .process-step::before {
      display: none;
    }
  }
</style>
