---
import AppPage from '../../layouts/AppPage.astro';
import Section from '../../components/Section.astro';
import StepGrid from '../../components/StepGrid.astro';
import Screenshot from '../../components/Screenshot.astro';
---

<AppPage
  name="Rank Cascading for Jira"
  platform="Jira"
  tagline="Keep priorities aligned across your issue hierarchy"
  icon="/icon-rank-cascading.png"
  description="Rank Cascading automatically calculates priority ranks for your Jira work items based on board position, status hierarchy, and swimlane grouping — with optional inheritance to child issues. Ranks are written to a number field of your choice, making them available in filters, dashboards, and automations."
  features={[
    'Board-Based Ranking — position on your board determines base rank',
    'Status Priority — In Progress ranks before Ready, which ranks before Backlog',
    'Swimlane Grouping — group by Epic, Assignee, Priority, or custom JQL',
    'Rank Inheritance — child issues inherit parent rank via Parent Hierarchy, Issue Links, or Both',
    'Portfolio → Team Board — leadership prioritizes Epics, team backlogs update automatically',
    'Cross-Board Ranking — aggregate work items across multiple boards',
    'Visual Rank Map — interactive hierarchy view with swimlanes and epics',
    'Conflict Detection — health scoring (A-F) identifies ranking inconsistencies',
    'What-If Simulation — test rank changes before committing',
    'Preview Mode — see exactly what will change before applying',
    'Scheduled Sync — automatic daily rank updates',
  ]}
  marketplaceUrl="https://marketplace.atlassian.com/apps/1844919935/rank-cascading-for-jira"
>
  <Section title="How it works">
    <StepGrid steps={[
      { title: '1. Portfolio Board', description: 'Set up a Scrum or Kanban board as your source. Arrange Epics by dragging them to define priority.' },
      { title: '2. Create Cascade', description: 'Select your board, a target number field, status priority order, and optionally enable inheritance (Parent Hierarchy, Issue Links, or Both).' },
      { title: '3. Sync', description: 'Run a sync — ranks are calculated and written to your target field. Child issues inherit their parent Epic\'s rank.' },
      { title: '4. Team Board', description: 'Create a team board with ORDER BY your rank field. The backlog automatically reflects portfolio priorities — no manual ranking needed.' },
    ]} />
  </Section>

  <Section title="Portfolio → Team Board">
    <p class="text-muted-foreground mb-4">
      The most powerful pattern: Leadership prioritizes Epics on a Portfolio board, and every team backlog updates automatically after sync.
      Manual ranking is disabled on team boards — priorities flow from the cascade, not from drag-and-drop.
      One sync updates all team boards simultaneously.
    </p>
  </Section>

  <Section title="Screenshots">
    <div class="space-y-8">
      <Screenshot title="App Overview" src="/apps/rank-cascading-jira/app-overview.png" alt="Rank Cascading Overview" />
      <Screenshot title="Cascade Configuration" src="/apps/rank-cascading-jira/cascade-list.png" alt="Cascade List" />
      <Screenshot title="Visual Rank Map" src="/apps/rank-cascading-jira/rank-map.png" alt="Visual Rank Map" />
      <Screenshot title="What-If Simulation" src="/apps/rank-cascading-jira/what-if-simulation.png" alt="What-If Simulation" />
    </div>
  </Section>
</AppPage>
