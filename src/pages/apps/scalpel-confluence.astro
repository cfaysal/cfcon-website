---
import AppPage from '../../layouts/AppPage.astro';
import Section from '../../components/Section.astro';
import StepGrid from '../../components/StepGrid.astro';
import Screenshot from '../../components/Screenshot.astro';
---

<AppPage
  name="Scalpel for Confluence"
  platform="Confluence"
  tagline="The precision admin toolkit for Confluence Cloud"
  icon="/icon-scalpel-confluence.png"
  description="Over time, Confluence instances accumulate orphaned personal spaces, pages nobody has viewed in years, broken macros, label chaos, and permission configurations that no longer make sense. Scalpel finds these issues automatically and gives you the tools to fix them — safely and with full audit trail."
  features={[
    'Health Score Dashboard — instance-wide grade (A-F) with trend tracking',
    '13 Scanner Modules — orphaned spaces, inactive users, broken macros, permission audit, and more',
    'Deep Scan — 7-layer space anatomy: page tree, permissions, attachments, labels, macros, versions, trash',
    'Dependency Graph — interactive D3 visualization of space structure with zoom, pan, and PNG export',
    'Diagnosis Engine — 3-tier root cause analysis',
    '10 Admin Tools — Space, Page, Permission, Template, Trash, Macro, Attachment, Label Manager, User Anonymizer, Page Export',
    'Smart Link Scanner — detect broken Smart Links to deleted pages, work items, or spaces',
    'Scheduled Scans — automated recurring scans (Standard+)',
    'Export as CSV, PDF, or Confluence page',
    'Full Audit Log — every action tracked with actor, timestamp, and details',
  ]}
  marketplaceUrl="https://marketplace.atlassian.com/apps/1773510668/scalpel-for-confluence"
>
  <Section title="How it works">
    <StepGrid steps={[
      { title: 'Pre-Screen', description: 'Instance profile with key metrics (spaces, users, pages, attachments, trash)' },
      { title: 'Scan', description: '13 scanner modules discover hygiene issues across your instance' },
      { title: 'Deep Scan', description: 'Anatomize individual spaces in 7 layers with interactive D3 graph' },
      { title: 'Diagnose', description: '3-tier root cause analysis to understand why issues exist' },
      { title: 'Fix', description: '10 built-in tools to clean up issues with full audit trail' },
    ]} />
  </Section>

  <Section title="Screenshots">
    <div class="space-y-8">
      <Screenshot title="Dashboard with Health Score" src="/apps/scalpel-confluence/dashboard.png" alt="Scalpel for Confluence Dashboard showing health score, findings breakdown, scanner cards, and trend chart" />
      <Screenshot title="13 Scanner Modules" src="/apps/scalpel-confluence/scanners.png" alt="All 13 scanner modules with findings count and category badges" />
      <Screenshot title="Deep Scan — 7-Layer Space Anatomy" src="/apps/scalpel-confluence/deepscan.png" alt="Deep Scan table view showing page tree, permissions, attachments, labels, macros, version bloat, and trash layers" />
      <Screenshot title="Deep Scan — Interactive D3 Dependency Graph" src="/apps/scalpel-confluence/deepscan_d3.png" alt="Interactive D3 visualization of space structure with expandable nodes for macros, labels, attachments, and more" />
      <Screenshot title="Confluence Management Suite (10 Tools)" src="/apps/scalpel-confluence/tools.png" alt="Admin tools: Space Manager, Page Manager, Permission Manager, Template Manager, Trash Manager, Macro Manager, Attachment Manager, Label Manager, User Anonymizer, Page Export" />
      <Screenshot title="Settings — Scan Configuration & License Cost" src="/apps/scalpel-confluence/settings_1.png" alt="Settings page with scan thresholds, export options, edition info, and license cost estimation" />
      <Screenshot title="Audit Log" src="/apps/scalpel-confluence/audit.png" alt="Audit log showing all actions with type filters, targets, actors, and timestamps" />
    </div>
  </Section>
</AppPage>
