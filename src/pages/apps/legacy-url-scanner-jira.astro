---
import AppPage from '../../layouts/AppPage.astro';
import Section from '../../components/Section.astro';
import StepGrid from '../../components/StepGrid.astro';
import Screenshot from '../../components/Screenshot.astro';
---

<AppPage
  name="Legacy URL Scanner for Jira"
  platform="Jira"
  tagline="Find and fix outdated URLs after your Cloud migration"
  icon="/icon-legacy-url-scanner.png"
  description="Migrated from Jira Server or Data Center? Thousands of work items may still contain links pointing to your old instance. Legacy URL Scanner finds them automatically, replaces them with modern Jira Smart Links, and gives you the governance tools to keep your instance clean going forward."
  features={[
    'Smart URL Detection — descriptions, comments, environment fields, custom fields',
    'Content-Type Filter — scan work items, comments, or remote links',
    'Bulk Fix & Async Fix — individual, bulk, or enterprise-grade async jobs',
    'URL Mappings — map old domains to new Cloud domains with Smart Link conversion',
    'Governance Rules — Block, Allow, Warn, or Replace URLs by pattern',
    'Key Resolution — automatically resolve moved work items (OLD-123 to NEW-456)',
    'User Reference Scanner — detect broken/deactivated user references',
    'Scheduled Scans with auto-fix and cross-platform Confluence reporting',
    'REGEXP Mode — custom regex patterns with capture groups (Advanced)',
    'Notifications — Slack, Microsoft Teams, and custom webhooks',
  ]}
  marketplaceUrl="https://marketplace.atlassian.com/apps/72889190/legacy-url-scanner-for-jira"
>
  <Section title="How it works">
    <StepGrid steps={[
      { title: 'Configure', description: 'Enter your old server hostnames and map them to Cloud URLs' },
      { title: 'Scan', description: 'Scan by project, JQL query, or instance-wide to find all legacy URLs' },
      { title: 'Fix', description: 'Preview changes, then replace individually or in bulk with Smart Links' },
    ]} />
  </Section>

  <Section title="Screenshots">
    <div class="space-y-8">
      <Screenshot title="Dashboard" src="/apps/legacy-url-scanner-jira/dashboard.png" alt="Legacy URL Scanner Dashboard" />
      <Screenshot title="Scan Configuration" src="/apps/legacy-url-scanner-jira/scan.png" alt="Scan Configuration" />
      <Screenshot title="Results with Preview" src="/apps/legacy-url-scanner-jira/results-expanded.png" alt="Scan Results with Preview" />
      <Screenshot title="Domain Governance" src="/apps/legacy-url-scanner-jira/governance.png" alt="Domain Governance Rules" />
    </div>
  </Section>
</AppPage>
