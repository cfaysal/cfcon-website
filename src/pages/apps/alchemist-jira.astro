---
import AppPage from '../../layouts/AppPage.astro';
import Section from '../../components/Section.astro';
import StepGrid from '../../components/StepGrid.astro';
import Screenshot from '../../components/Screenshot.astro';
import InfoCard from '../../components/InfoCard.astro';
---

<AppPage
  name="Alchemist for Jira"
  platform="Jira"
  tagline="Convert ScriptRunner & SIL scripts to Cloud in seconds"
  icon="/icon-alchemist.png"
  description="Migrating from Jira Server or Data Center and stuck with legacy scripts? Alchemist analyzes your Groovy, SIL, ScriptRunner, and Behaviour scripts and converts them to Cloud format using 500+ deterministic regex conversion patterns — no AI hallucination, just pattern-based transformations with built-in risk assessment and Cloud Readiness Score."
  features={[
    'HAPI-First Conversion — 70% shorter code than verbose REST output',
    'Language Detection — auto-detect Groovy vs. SIL from script content',
    'Risk Analysis — Cloud Readiness Score (0-100) per script',
    '500+ conversion patterns — ScriptRunner Groovy, SIL, Behaviours, Jira Expressions',
    'Native Automation Detection — tells you when a script is unnecessary because built-in Jira Automation suffices',
    'Script Builder — visual drag-and-drop script assembly with 26 blocks across 8 categories (Standard+)',
    'Use-Case Templates — 6 ready-made workflows (Cascade Priority, Bulk Update, WSJF Score, and more)',
    'Alchemist AI — Rovo Agent for conversational migration and AI-assisted completion of unconverted fragments (Advanced)',
    'Migration Wizard — 4-step guided migration (Input, Analyze, Convert, Deploy)',
    'Bulk Upload — multi-file batch conversion',
    'Syntax Validation — validate converted code for common errors',
    'Deploy Helper — step-by-step deployment guides per script type',
    'Export as JSON, PDF, or plain script',
  ]}
  marketplaceUrl="https://marketplace.atlassian.com/apps/948516184/alchemist-for-jira"
>
  <Section title="Supported conversions">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <InfoCard title="ScriptRunner Groovy" description="Java API to Cloud Groovy (HAPI/REST) — 476 conversion patterns" />
      <InfoCard title="Power Scripts (SIL)" description="SIL DC to SIL Cloud — 181 patterns" />
      <InfoCard title="Behaviours" description="Server Behaviours to ScriptRunner Behaviours Cloud" />
      <InfoCard title="Jira Expressions" description="31 conversion patterns + 280 templates (conditions, validators, calculated fields)" />
    </div>
  </Section>

  <Section title="Script Builder" subtitle="Don't have a legacy script to convert? Build new Cloud scripts visually — no coding required. Drag blocks, pick a template, or describe what you need and let AI figure out the rest.">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <InfoCard title="Visual Block Assembly" description="26 blocks across 8 categories — Work Items, Search, Fields, Transitions, Comments, Notifications, Control Flow, Users. Assemble scripts by stacking blocks with live HAPI Groovy preview." />
      <InfoCard title="Use-Case Templates" description="6 ready-made workflows: Cascade Priority, Bulk Update, WSJF Score, Cross-Project Clone, Sprint Cleanup, and Epic Completion. One click loads a pre-built block assembly." />
      <InfoCard title="AI Script Generator" description="Describe what you need in plain text. Alchemist routes your request through 3 stages: native Jira Automation detection, template matching, and Rovo AI generation for complex cases." />
    </div>
  </Section>

  <Section title="How it works">
    <StepGrid steps={[
      { title: 'Input', description: 'Paste a script or upload multiple files' },
      { title: 'Analyze', description: 'Risk assessment with Cloud Readiness Score' },
      { title: 'Convert', description: 'Pattern-based transformation to Cloud format' },
      { title: 'Deploy', description: 'Step-by-step deployment guide per script type' },
    ]} />
  </Section>

  <Section title="Screenshots">
    <div class="space-y-8">
      <Screenshot title="Script Builder — Overview" src="/apps/alchemist-jira/script-builder.png" alt="Visual Script Builder with 26 blocks and 6 templates" />
      <Screenshot title="Native Automation Detection" src="/apps/alchemist-jira/script-builder-native-detection.png" alt="Native Automation Detection — You don't need a script for this" />
      <Screenshot title="Script Builder — Assembly with Generated Code" src="/apps/alchemist-jira/script-builder-full.png" alt="Script Builder with blocks assembled and generated HAPI code" />
      <Screenshot title="Alchemist AI (Rovo Agent)" src="/apps/alchemist-jira/script-builder-rovo.png" alt="Alchemist AI — Rovo Agent generating Cloud HAPI script" />
    </div>
  </Section>
</AppPage>
