---
import AppPage from '../../layouts/AppPage.astro';
import Section from '../../components/Section.astro';
import StepGrid from '../../components/StepGrid.astro';
import Screenshot from '../../components/Screenshot.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
---

<AppPage
  name="Scalpel for Jira"
  platform="Jira"
  tagline="The precision admin toolkit for Jira Cloud"
  icon="/icon-scalpel-jira.png"
  description="Scalpel gives Jira admins the tools they need to analyze, clean up, and optimize their instance. Scan for configuration debt, diagnose root causes, and fix issues — all from a single interface. Think of it as a health check for your Jira instance."
  features={[
    'Health Score Dashboard — instance-wide grade (A-F) with trend tracking',
    '12+ Scanner Modules — orphaned spaces, inactive users, stale projects, permission gaps',
    'Deep Scan Anatomy Map — interactive scheme visualization with drill-down',
    'Diagnosis Engine — 3-tier root cause analysis',
    'Workflow Manager — analyze transitions, detect broken rules & missing plugins',
    'Config Element Management Suite — managers for schemes, fields, screens & more',
    'Filter & Dashboard Audit — find broken JQL, orphaned filters & stale dashboards',
    'User Offboarding & GDPR Anonymization',
    'Scheduled Scans with notifications',
    'Export as CSV, JSON, or Confluence page',
    'Full Audit Log — every action tracked',
    'Runs on Atlassian — no external data transfer',
  ]}
  marketplaceUrl="https://marketplace.atlassian.com/apps/1522073931/scalpel-for-jira"
>
  <Section title="How it works">
    <StepGrid steps={[
      { title: 'Scan', description: 'Run 12+ scanner modules to discover configuration issues across your instance' },
      { title: 'Diagnose', description: 'Deep Scan cross-references and 3-tier analysis to understand root causes' },
      { title: 'Plan', description: 'Treatment plans with What-If simulation before making changes' },
      { title: 'Execute', description: 'Apply fixes with rollback support and full audit trail' },
    ]} />
  </Section>

  <Section title="Workflow Manager" subtitle="Analyze workflow transitions, detect broken plugin rules, disabled conditions, and missing post-functions — all in one view.">
    <VideoEmbed youtubeId="hIr6NttuQOk" title="Scalpel for Jira — Workflow Manager" />
  </Section>

  <Section title="Screenshots">
    <div class="space-y-8">
      <Screenshot title="Dashboard — Health Score, Findings Breakdown & Trend" src="/apps/scalpel-jira/Dashboard.png" alt="Scalpel Dashboard with Health Score and Trend" />
      <Screenshot title="Deep Scan — Anatomy Map with Scheme Relationships" src="/apps/scalpel-jira/anatomy_map_new.png" alt="Deep Scan Anatomy Map" />
      <Screenshot title="Anatomy Map — Drill-Down to Screen Fields" src="/apps/scalpel-jira/anatomy_map_new_drill.png" alt="Anatomy Map Drill-Down" />
      <Screenshot title="Config Element Management Suite" src="/apps/scalpel-jira/scalpel_managers_suite.png" alt="Config Element Management Suite" />
      <Screenshot title="Filter & Dashboard Audit — Broken JQL Detection" src="/apps/scalpel-jira/filter_jql_broken.png" alt="Filter and Dashboard Audit" />
      <div>
        <h3 class="text-sm font-medium text-text-light mb-2">Settings — Scan Configuration, Detection & Export</h3>
        <div class="glass-card rounded-2xl overflow-hidden p-1 space-y-1">
          <img src="/apps/scalpel-jira/settings_top.png" alt="Scalpel Settings — Scan Configuration" class="rounded-xl w-full lightbox-trigger" loading="lazy" />
          <img src="/apps/scalpel-jira/settings_mid.png" alt="Scalpel Settings — Scheduled Scans & Integrations" class="rounded-xl w-full lightbox-trigger" loading="lazy" />
          <img src="/apps/scalpel-jira/settings_buttom.png" alt="Scalpel Settings — Database & Danger Zone" class="rounded-xl w-full lightbox-trigger" loading="lazy" />
        </div>
      </div>
    </div>
  </Section>
</AppPage>
