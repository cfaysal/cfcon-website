---
import Layout from '../layouts/Layout.astro';
import AppCard from '../components/AppCard.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import StatsSection from '../components/StatsSection.tsx';
import LogoMarquee from '../components/LogoMarquee.tsx';
import Testimonials from '../components/Testimonials.tsx';

const apps = [
  {
    name: 'Scalpel for Jira',
    platform: 'Jira' as const,
    description: 'Powerful admin toolkit for Jira. Manage custom fields, workflows, screens, and more — clean up your instance with precision.',
    href: '/apps/scalpel-jira',
    icon: '/icon-scalpel-jira.png',
  },
  {
    name: 'Scalpel for Confluence',
    platform: 'Confluence' as const,
    description: 'Admin toolkit for Confluence. Analyze spaces, clean up content, manage permissions, and keep your wiki in shape.',
    href: '/apps/scalpel-confluence',
    icon: '/icon-scalpel-confluence.png',
  },
  {
    name: 'Legacy URL Scanner for Jira',
    platform: 'Jira' as const,
    description: 'Find and replace outdated Jira Server/Data Center URLs across your Cloud instance. Ensure a clean migration.',
    href: '/apps/legacy-url-scanner-jira',
    icon: '/icon-legacy-url-scanner.png',
  },
  {
    name: 'Legacy URL Scanner for Confluence',
    platform: 'Confluence' as const,
    description: 'Detect and fix legacy URLs in Confluence pages, blogs, and comments after migrating to Cloud.',
    href: '/apps/legacy-url-scanner-confluence',
    icon: '/icon-legacy-url-scanner.png',
  },
  {
    name: 'Alchemist for Jira',
    platform: 'Jira' as const,
    description: 'Convert ScriptRunner, SIL & Groovy scripts to native Jira Automation and Forge. Built-in risk assessment and 1,100+ conversion patterns.',
    href: '/apps/alchemist-jira',
    icon: '/icon-alchemist.png',
  },
  {
    name: 'Rank Cascading for Jira',
    platform: 'Jira' as const,
    description: 'Cascade ranking from epics to child issues. Keep your backlog priorities aligned across the hierarchy.',
    href: '/apps/rank-cascading-jira',
    icon: '/icon-rank-cascading.png',
  },
];

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'CFCON',
  url: 'https://cfcon.org',
  logo: 'https://cfcon.org/logo.png',
  description: 'Atlassian Consulting & Marketplace Apps. We help teams optimize their workflows and get the most out of the Atlassian ecosystem.',
  sameAs: [
    'https://marketplace.atlassian.com/vendors/69072148',
  ],
};
---

<Layout title="Home" jsonLd={organizationJsonLd}>
  <!-- Hero -->
  <section class="hero-glow bg-gradient-to-b from-primary-dark via-primary-dark to-surface-dark text-white py-28 md:py-36">
    <!-- Aurora background -->
    <div class="aurora-bg">
      <div class="aurora-beam aurora-beam-1"></div>
      <div class="aurora-beam aurora-beam-2"></div>
      <div class="aurora-beam aurora-beam-3"></div>
    </div>

    <!-- Floating orbs -->
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>

    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
      <img src="/logo.png" alt="CFCON Consulting" class="h-36 md:h-52 mx-auto mb-10 drop-shadow-2xl scale-in" />
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6 tracking-tight blur-in">
        Atlassian Consulting<br/><span class="gradient-text-brand">& Marketplace Apps</span>
      </h1>
      <p class="text-lg md:text-xl text-white/60 leading-relaxed mb-10 max-w-2xl mx-auto fade-in fade-in-delay-1">
        We help organizations get the most out of Jira and Confluence. From expert consulting to purpose-built apps on the Atlassian Marketplace.
      </p>
      <div class="flex flex-wrap gap-4 justify-center mb-14 fade-in fade-in-delay-2">
        <a href="/apps" class="btn-glow inline-flex items-center px-8 py-4 bg-primary text-white font-semibold rounded-xl text-lg transition-colors">
          Explore our Apps
        </a>
        <a href="/contact" class="btn-outline-glow inline-flex items-center px-8 py-4 border border-white/20 text-white font-semibold rounded-xl text-lg">
          Get in touch
        </a>
      </div>
      <div class="flex flex-wrap gap-3 justify-center fade-in fade-in-delay-3">
        <span class="badge-shimmer inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-sm font-medium backdrop-blur-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 5.143L5.143 11.571l6.428 6.429 6.429-6.429-6.429-6.428zm0-2.857L18.857 9.57l-7.286 7.286L4.286 9.571 11.571 2.286z"/><path d="M11.571 5.143l-6.428 6.428h12.857l-6.429-6.428z" opacity=".4"/></svg>
          Atlassian Partner
        </span>
        <span class="badge-shimmer inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-sm font-medium backdrop-blur-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Certified Professional
        </span>
        <span class="badge-shimmer inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-sm font-medium backdrop-blur-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Runs on Atlassian
        </span>
      </div>
    </div>
  </section>

  <!-- Trusted by -->
  <section class="py-12 border-b border-white/5 bg-surface-dark">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-center text-xs font-semibold tracking-widest uppercase text-text-light/50 mb-4">Trusted by teams at</p>
      <LogoMarquee client:visible />
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 border-b border-white/5 grid-pattern">
    <div class="max-w-6xl mx-auto px-6">
      <StatsSection client:load />
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-24 bg-surface dot-pattern">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14 fade-in">
        <p class="text-primary text-sm font-semibold tracking-widest uppercase mb-3">What we do</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Two pillars, one goal</h2>
        <p class="text-text-light max-w-2xl mx-auto text-lg">
          Making your Atlassian tools work harder for you.
        </p>
      </div>
      <div class="bento-grid stagger-children">
        <!-- Consulting — wide -->
        <div class="bento-wide glow-card">
          <div class="glow-card-inner rounded-2xl">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5 ring-1 ring-primary/20">
              <svg width="24" height="24" fill="none" stroke="currentColor" class="text-primary" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Consulting</h3>
            <p class="text-text-light leading-relaxed mb-5">
              Process analysis, cloud migrations, infrastructure design, and ongoing support. We optimize your Atlassian setup so your team can focus on what matters.
            </p>
            <div class="grid grid-cols-2 gap-2.5 text-sm text-text-light">
              <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> Cloud migration & strategy</span>
              <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> Process optimization</span>
              <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> Administration & support</span>
              <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> Training & enablement</span>
            </div>
          </div>
        </div>

        <!-- Security -->
        <div class="glow-card">
          <div class="glow-card-inner rounded-2xl flex flex-col items-center text-center">
            <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mb-5 ring-1 ring-primary/20">
              <svg width="28" height="28" fill="none" stroke="currentColor" class="text-primary" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Runs on Forge</h3>
            <p class="text-sm text-text-light leading-relaxed">No external servers. Your data never leaves your Atlassian instance.</p>
          </div>
        </div>

        <!-- Marketplace Apps -->
        <div class="glow-card">
          <div class="glow-card-inner rounded-2xl flex flex-col items-center text-center">
            <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mb-5 ring-1 ring-accent/20">
              <svg width="28" height="28" fill="none" stroke="currentColor" class="text-accent" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="14" y="3" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="3" y="14" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="14" y="14" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Marketplace Apps</h3>
            <p class="text-sm text-text-light leading-relaxed">Purpose-built Forge apps for Jira & Confluence with Free, Standard & Advanced editions.</p>
          </div>
        </div>

        <!-- Editions — wide -->
        <div class="bento-wide glow-card">
          <div class="glow-card-inner rounded-2xl">
            <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5 ring-1 ring-accent/20">
              <svg width="24" height="24" fill="none" stroke="currentColor" class="text-accent" stroke-width="2"><path d="M23 6l-9.5 9.5-5-5L1 18" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 6h6v6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Built by practitioners</h3>
            <p class="text-text-light leading-relaxed mb-5">
              Every app starts with real pain points we've encountered in production Atlassian environments — then engineered into tools for everyone.
            </p>
            <div class="grid grid-cols-2 gap-2.5 text-sm text-text-light">
              <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span> Real-world admin needs</span>
              <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span> Continuous improvement</span>
              <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span> No feature bloat</span>
              <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span> Active maintenance</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- How we build -->
  <section class="py-24 grid-pattern">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14 blur-in">
        <p class="text-primary text-sm font-semibold tracking-widest uppercase mb-3">How we build</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">From experience to product</h2>
        <p class="text-text-light max-w-2xl mx-auto text-lg">
          Every app starts with real problems we've solved as consultants — then engineered into tools for everyone.
        </p>
      </div>
      <ProcessFlow />
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Apps Preview -->
  <section class="py-24 grid-pattern">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14 fade-in">
        <p class="text-primary text-sm font-semibold tracking-widest uppercase mb-3">Our Apps</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Built for Atlassian admins</h2>
        <p class="text-text-light max-w-2xl mx-auto text-lg">
          Admin tools built by Atlassian practitioners, for Atlassian practitioners.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-children">
        {apps.map((app) => (
          <div class="h-full">
            <AppCard {...app} />
          </div>
        ))}
      </div>
      <div class="text-center mt-12 fade-in">
        <a href="https://marketplace.atlassian.com/vendors/69072148" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-primary font-medium hover:underline underline-offset-4 transition-colors">
          View all on Atlassian Marketplace
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5-5-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>
  <div class="section-divider"></div>

  <!-- Testimonials -->
  <section class="py-24 bg-surface dot-pattern">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14 fade-in">
        <p class="text-primary text-sm font-semibold tracking-widest uppercase mb-3">What people say</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Trusted by Atlassian teams</h2>
      </div>
      <div class="fade-in">
        <Testimonials client:visible />
      </div>
    </div>
  </section>
</Layout>
